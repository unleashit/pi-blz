{
  "name": "@blazer2k/pi-blz",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "check": "tsc --noEmit -p tsconfig.json",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "publish:pkgs": "npm publish --workspaces --access public",
    "publish:dry": "npm publish --workspaces --access public --dry-run"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "*",
    "@types/bun": "^1.3.14",
    "prettier": "^3.8.4",
    "typescript": "^5"
  },
  "pi": {
    "extensions": [
      "packages/searxng-suite/src/index.ts",
      "packages/pi-personality/src/index.ts",
      "packages/pi-ui-enhancements/src/index.ts"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
